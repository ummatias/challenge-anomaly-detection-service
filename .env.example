
# Arbitrary threshold, but 30 is a common rule of thumb for std estimation.
# With fewer points, the sample std is unreliable
MIN_TRAIN_POINTS=30 

# WORKERS=1 is intentional
# Can scale horizontally with a multiple containers behind a load balancer

# Change asyncio to redis locks and queue if we want to scale across multiple
# instances. This challenge spec determinates response on /fit, using redis may
# need new endpoints to check job result
WORKERS=1 

# Number of worker threads for handling /fit requests. 
# More workers can handle more concurrent training requests, but may increase resource contention.
# Since the challenge spec doesn't require horizontal scaling, we can keep this simple with a few workers.
FIT_WORKERS=4

#Local storage root directory
STORAGE_ROOT=storage

API_PORT=8000
GRAFANA_PASSWORD=admin